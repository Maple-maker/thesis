  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:setup": "bash scripts/setup-ios.sh",
    "web": "expo start --web",
    "lint": "expo lint",
    "generate:etf-catalog": "node scripts/generate-etf-catalog.mjs",
    "generate:market-catalogs": "node scripts/generate-market-catalogs.mjs",
    "generate:market-catalogs:safe": "node scripts/generate-market-catalogs.mjs --delay-ms 3000 --batch-size 5 --resume",
    "bootstrap:stocks-catalog": "node scripts/bootstrap-stocks-catalog.mjs",
    "postinstall": "patch-package",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:verify-deepseek": "cd server && npm run verify:deepseek",
    "server:test-chat": "cd server && npm run test:chat",
    "server:stop": "lsof -ti :8787 | xargs kill -9 2>/dev/null || true",
    "server:pace": "curl -s http://localhost:8787/v1/health | python3 -m json.tool",
    "ios:sim": "expo start --ios --lan",
    "ios:sim:clear": "expo start --ios --lan --clear",
    "ios:dev": "bash scripts/run-ios-dev.sh",
    "metro:check": "bash scripts/check-metro-connectivity.sh",
    "metro:ensure": "bash scripts/ensure-metro.sh",
    "xcode": "bash scripts/xcode-with-metro.sh",
    "dev": "bash scripts/dev.sh",
    "dev:sim": "npm run metro:stop && npm run ios:sim:clear",
    "metro:stop": "lsof -ti :8081 | xargs kill -9 2>/dev/null || true",
    "dev:ios": "expo run:ios",
    "setup:agent-tooling": "bash scripts/setup-agent-tooling.sh",
    "codegraph:sync": "codegraph sync",
    "codegraph:status": "codegraph status"
