# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (never commit secrets)
.env
.env*.local
server/.env

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android
.DS_Store
__pycache__/
*.pyc

# Yahoo catalog generation cache
scripts/.cache/

# CodeGraph local index (machine-specific; re-run setup:agent-tooling)
.codegraph/

# Local Netlify folder
.netlify

# Relay spec containing burn API keys — rotate keys, then remove this line to commit the doc
docs/relay-specs/quick-start-YOUR-SETUP.md

# Supabase CLI local state (machine-specific)
supabase/.temp/

# Claude Code runtime locks
.claude/scheduled_tasks.lock
