PORT=8787

# ── LLM PACE (Primary → Alternate → Contingency → Emergency) ──
# DeepSeek-only is fine: ASSISTANT_PACE=deepseek
# Cursor (CURSOR_API_KEY) is NOT used here — see docs/llm-pace-plan.md
ASSISTANT_PACE=deepseek

# P — Primary (cheapest strong default)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat → deprecated Jul 2026; use v4-flash
ASSISTANT_MODEL_PRO=deepseek-v4-flash
ASSISTANT_MODEL_FREE=deepseek-v4-flash
# ASSISTANT_DEBUG=1
# Live macro tools for Ask CFO (Fed funds, yields, headlines). Set to 0 to disable tool loop.
# ASSISTANT_TOOLS=1
# Free FRED API key — https://fred.stlouisfed.org/docs/api/api_key.html (improves Fed funds + CPI)
# FRED_API_KEY=your-fred-api-key

# A — Alternate (Claude Haiku — cheap, reliable)
ANTHROPIC_API_KEY=sk-ant-your-key
PACE_ALTERNATE_MODEL_PRO=claude-3-5-haiku-20241022
PACE_ALTERNATE_MODEL_FREE=claude-3-5-haiku-20241022

# C — Contingency (OpenAI mini)
OPENAI_API_KEY=sk-your-openai-key
PACE_CONTINGENCY_MODEL=gpt-4o-mini

# E — Emergency (Gemini Flash — very cheap)
GEMINI_API_KEY=your-gemini-key
# or GOOGLE_API_KEY=your-gemini-key
PACE_EMERGENCY_MODEL=gemini-2.0-flash-lite

THESIS_APP_SECRET=dev-shared-secret-change-me

# Market data — Massive.com (formerly Polygon.io; same API keys)
# Get a key: https://massive.com/dashboard/api-keys
MASSIVE_API_KEY=
# Plan: basic (free EOD) | starter | developer | advanced | full
MASSIVE_PLAN=basic
# Legacy alias still works:
# POLYGON_API_KEY=
# Default host: api.massive.com — set MASSIVE_API_HOST=polygon for api.polygon.io
# MARKET_DATA_PROVIDER=polygon
# Live search + quotes — set 0 for bundled catalog only
# MARKET_LIVE_SEARCH=1
# Free tier defaults (see docs/massive-market-data.md):
# MARKET_API_GAP_MS=12500
# MARKET_QUOTE_CACHE_MS=900000
# Paid tier — faster refresh:
# MASSIVE_PLAN=starter
# MARKET_API_GAP_MS=300
# MARKET_QUOTE_CACHE_MS=60000
# Legacy Yahoo throttle if MARKET_DATA_PROVIDER=yahoo
# MARKET_YAHOO_GAP_MS=2000
# Search result cache TTL ms (default 900000 = 15 min)
# MARKET_SEARCH_CACHE_MS=900000

# Expo does NOT read server/.env — copy the two EXPO_PUBLIC_* lines to repo root .env (see /.env.example)
REVENUECAT_WEBHOOK_SECRET=
CORS_ORIGIN=*
DEV_PRO_USER_IDS=dev-test-user

# Plaid (optional)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
