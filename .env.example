# Expo reads THIS file at repo root (not server/.env).
# Copy: cp .env.example .env

# API endpoint (localhost for dev, Fly.io for production)
EXPO_PUBLIC_THESIS_API_URL=http://127.0.0.1:8787

# App authentication secret — MUST match THESIS_APP_SECRET in server/.env
# In production, use a strong random value from: openssl rand -base64 32
EXPO_PUBLIC_THESIS_APP_KEY=dev-shared-secret-change-me

# Supabase — OAuth provider for sign-in
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — error tracking (optional, set the DSN from Sentry dashboard)
EXPO_PUBLIC_SENTRY_DSN=
